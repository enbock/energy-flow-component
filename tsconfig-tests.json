{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "module": "commonjs",
        "target": "es2022",
        "moduleResolution": "node",
        "rootDir": ".",
        "outDir": "./.testBuild/",
        "sourceMap": true,
        "noEmit": false,
        "types": [
            "node"
        ],
        "typeRoots": [
            "node_modules/@types",
            "./src"
        ]
    },
    "include": [
        "src",
        "test"
    ],
    "exclude": [
        "node_modules",
        "webpack.config.ts"
    ]
}
