{
  "compilerOptions": {
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "nodenext",
    "target": "ESNext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "outDir": "./build/",
    "noImplicitAny": true,
    "moduleResolution": "nodenext",
    "sourceRoot": "src",
    "sourceMap": true,
    "lib": [
      "dom",
      "DOM.Iterable",
      "ESNext"
    ],
    "types": [
      "node"
    ],
    "typeRoots": [
      "node_modules/@types",
      "./src"
    ]
  },
  "include": [
    "src",
    "test/globals.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
