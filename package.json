{
  "name": "@enbock/energy-flow-component",
  "version": "0.3.2",
  "description": "A visualisation of a energy flow.",
  "main": "index.js",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "webpack serve --open --mode development --no-open --no-hot --stats-error-details",
    "build": "webpack --mode production",
    "test:compile": "rimraf .testBuild && tsc -p tsconfig-tests.json",
    "test:watch": "rimraf .testBuild && concurrently -k -n tsc,test \"tsc -p tsconfig-tests.json --watch\" \"node --import ./test/globalSetup.cjs --test --watch .testBuild/**/*.test.js\"",
    "test": "npm run test:compile && node --import ./test/globalSetup.cjs --test .testBuild/src/**/*.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enbock/energy-flow-component.git"
  },
  "keywords": [
    "particle",
    "clean",
    "code",
    "energy",
    "visualisation"
  ],
  "author": "Endre Bock <dev@itbock.de>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/enbock/energy-flow-component/issues"
  },
  "homepage": "https://github.com/enbock/energy-flow-component#readme",
  "devDependencies": {
    "@types/jsdom": "*",
    "@types/node": "*",
    "@types/webpack-env": "*",
    "concurrently": "*",
    "copy-webpack-plugin": "*",
    "css-loader": "*",
    "jsdom": "*",
    "rimraf": "*",
    "ts-loader": "*",
    "typescript": "*",
    "webpack": "*",
    "webpack-cli": "*",
    "webpack-dev-server": "*"
  }
}
